# Flask
SECRET_KEY=랜덤-긴-문자열-배포시-필수
SESSION_COOKIE_SECURE=1

# 화면 우상단·/healthz 에 표시 (미설정 시 코드의 APP_VERSION_DEFAULT 사용). 예: 1.0.1 또는 v1.0.1
# APP_VERSION=1.0.1

# Google OAuth (Google Cloud Console > 사용자 인증 정보 > OAuth 2.0 클라이언트 ID)
# 승인된 리디렉션 URI: https://<도메인>/login/google/authorized
# 로컬: http://127.0.0.1:5000/login/google/authorized
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 선택: 사내 Google Workspace만 (이메일 @도메인 검증)
ALLOWED_EMAIL_DOMAIN=

# 선택: 로그인 화면에서 hd= 파라미터로 Workspace 한정 (Google 콘솔과 함께 사용)
GOOGLE_OAUTH_HOSTED_DOMAIN=

# 콤마로 구분. 이 이메일만 /admin 업로드·구글 시트 내보내기 가능 (AUTH_DISABLED 아닐 때 필수)
ADMIN_EMAILS=you@company.com

# Google Cloud Storage (원본 업로드/공개 결과 영구 저장)
GCP_PROJECT_ID=
GCS_BUCKET=
# GCS + 구글 시트보내기 공통: 서비스 계정 JSON 전체를 한 줄로(Railway Variables에 붙여넣기)
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Railway(구글 시트 내보내기) 체크 3줄만 기억하세요:
# ① 넣는 변수는 GOOGLE_APPLICATION_CREDENTIALS_JSON 하나 (ops-robot-keys.json 전체 복사)
# ② GOOGLE_APPLICATION_CREDENTIALS(파일 경로)는 Railway에서 삭제 — 이름이 비슷해 헷갈리면 둘 다 두지 마세요
# ③ 스프레드시트 공유에 JSON에 있는 client_email(편집자) 추가
# 로컬 전용 파일 경로(선택):
# GOOGLE_APPLICATION_CREDENTIALS=
# FM 기본정보는 관리자 화면 업로드 시 GCS 경로 metadata/fm_roster.xlsx 로 저장(최신만 유지)
# Railway에서만: 공개 급여「업로드 및 저장」은 기본 GCS 필수. GCS 없이 로컬만 허용(재배포 시 유실):
# ALLOW_PUBLISH_WITHOUT_GCS=1

# 로컬 개발 시 OAuth 없이 기존처럼 열기
# AUTH_DISABLED=1

# --- 상품화 인건비 대시보드 (/commercialization) — PostgreSQL ---
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# 선택: inspection.items 추가 WHERE (AND로 시작하거나 AND 없이 컬럼 조건만)
# COMMERCIALIZATION_ITEMS_EXTRA_WHERE=AND NOT COALESCE(is_re_exhibition, false)
# 기본 조회 시작월 (YYYY-MM). 미설정 시 2023-10
# COMMERCIALIZATION_RANGE_START=2023-10
# 월별 인건비: ym, fm_krw, logistics_krw 컬럼을 반환하는 SELECT 한 줄
# COMMERCIALIZATION_LABOR_MONTHLY_SQL=SELECT ... AS ym, ... AS fm_krw, ... AS logistics_krw
