# Flask
SECRET_KEY=랜덤-긴-문자열-배포시-필수
SESSION_COOKIE_SECURE=1

# 화면 우상단·/healthz 에 표시 (미설정 시 코드의 APP_VERSION_DEFAULT 사용). 예: 1.0.1 또는 v1.0.1
# APP_VERSION=1.0.1

# Google OAuth (Google Cloud Console > 사용자 인증 정보 > OAuth 2.0 클라이언트 ID)
# 승인된 리디렉션 URI: https://<도메인>/login/google/authorized
# 로컬: http://127.0.0.1:5000/login/google/authorized
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 선택: 사내 Google Workspace만 (이메일 @도메인 검증)
ALLOWED_EMAIL_DOMAIN=

# 선택: 로그인 화면에서 hd= 파라미터로 Workspace 한정 (Google 콘솔과 함께 사용)
GOOGLE_OAUTH_HOSTED_DOMAIN=

# 콤마로 구분. 이 이메일만 /admin 업로드·구글 시트 내보내기 가능 (AUTH_DISABLED 아닐 때 필수)
ADMIN_EMAILS=you@company.com

# Google Cloud Storage (원본 업로드/공개 결과 영구 저장)
GCP_PROJECT_ID=
GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# FM 기본정보는 관리자 화면 업로드 시 GCS 경로 metadata/fm_roster.xlsx 로 저장(최신만 유지)

# 로컬 개발 시 OAuth 없이 기존처럼 열기
# AUTH_DISABLED=1
